<div class="first-stack need-padding">
    <div class="left-Introduce">
        <div class="title-group">
            <span class="title"><%- theme.firstWarp.title %></span>
        </div>
        <div class="discription">
            <span class="discription-text"><%- theme.firstWarp.text %></span>
        </div>
        <% if (theme.firstWarp.button !== false){ %>
            <a href="<%= url_for(theme.firstWarp.buttonUrl) %>" class="about-button">
                <%= theme.firstWarp.buttonText || theme.firstWarp.button || '了解更多' %>
            </a>
        <% } %>
    </div>
    <div class="right-stack">
        <img class="banner-img" src="<%= url_for(theme.firstWarp.img) %>" alt="banner" title="banner">
    </div>
</div>

<% if (theme.notice.enable){ %>
    <div class="notice-banner">
        <div class="notice-content">
            <a href="<%= url_for(theme.notice.url) %>" class="notice-text">
                <span class="notice-typewriter-text"><%= theme.notice.text %></span>
            </a>
        </div>
    </div>
<% } %>
